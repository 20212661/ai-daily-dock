# Electron 二进制下载镜像（中国大陆网络必需）
# 解决 npm install 时 electron postinstall 从 GitHub 下载被中断、
# 导致 node_modules/electron/dist/electron.exe 缺失、npm run dev 报错的问题。
# @electron/get 会以最高优先级读取 npm_config_electron_mirror（即本文件的 electron_mirror）。
# 若你在海外且更想用官方源，注释掉下面这行即可。
electron_mirror=https://npmmirror.com/mirrors/electron/
